// ============================================================
// .env — Environment Variables
// ============================================================
// Copy this file to .env and fill in your values.
// Never commit the real .env to git.
//
// TODO 1: Set your MySQL connection values.
//         These are read by src/config/db.ts to create the pool.
//
// DB_HOST=localhost
// DB_PORT=3306
// DB_USER=rf_admin           ← MySQL user created in seed.sql DCL
// DB_PASSWORD=your_password
// DB_NAME=rideflow
//
// TODO 2: JWT secret — used by src/modules/auth/service.ts
//         Must be at least 32 random characters.
//
// JWT_SECRET=change_me_to_a_long_random_string
// JWT_EXPIRES_IN=7d          ← e.g. "7d", "24h"
//
// TODO 3: App port
// PORT=4000
//
// TODO 4: (Optional) Redis — used by src/config/redis.ts
//         for caching active ride state and surge ratios.
//         If you skip Redis, remove the redis import in server.ts.
//
// REDIS_URL=redis://127.0.0.1:6379
//
// TODO 5: (Optional) Socket.IO origin whitelist
//         Needed so the frontend at localhost:3000 can connect.
//
// CORS_ORIGIN=http://localhost:3000
